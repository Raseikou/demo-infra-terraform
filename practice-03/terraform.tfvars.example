# 注意: カスタム値を使う場合は、このファイルを `terraform.tfvars` としてコピーしてください。
# 例: `cp terraform.tfvars.example terraform.tfvars`

# AWS リージョン
aws_region = "ap-northeast-1"

# クラスター設定
cluster_name = "demo-eks-cluster"
environment  = "dev"

# VPC ネットワーク設定
vpc_cidr = "10.0.0.0/16"

# Worker ノード設定
node_desired_size   = 2
node_max_size       = 2
node_min_size       = 2

# インスタンスタイプ候補:
# 無料利用枠を意識する場合:
#   - t3.micro    (1 vCPU, 1GB RAM)   <- デモ向けにおすすめ
#   - t3.small    (2 vCPU, 2GB RAM)   <- もう少し余裕あり
#
# 本番向けの候補（無料利用枠の対象外）:
#   - t3.medium   (2 vCPU, 4GB RAM)
#   - m5.large    (2 vCPU, 8GB RAM)
#   - m6i.large   (2 vCPU, 8GB RAM)
node_instance_type = "t3.micro"

# コスト最適化: Spot インスタンスを利用する場合
# `main.tf` 側で次のように変更します:
# capacity_type = "SPOT"  # おおよそ 70% 前後のコスト削減が見込めます
