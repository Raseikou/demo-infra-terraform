# Example terraform.tfvars file for practice-05
# Copy this to terraform.tfvars and fill in your values
# DO NOT commit terraform.tfvars to version control (should be in .gitignore)

aws_region     = "ap-northeast-1"
app_name       = "demo-app-server"
instance_type  = "t3.small"
environment    = "dev"
vpc_id         = "vpc-xxxxxxxxx"     # Replace with your VPC ID
subnet_id      = "subnet-xxxxxxxxx"  # Replace with your Subnet ID
root_volume_size = 30
allowed_ssh_cidr = ["0.0.0.0/0"]     # Restrict this in production!
